#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
#  prepare-commit-msg — 커밋 제목 끝에 랜덤 깜찍 이모티콘 부여 (๑˃ᴗ˂)ﻭ
#  merge/squash/기존커밋(amend 등)에는 건드리지 않는다.
# ─────────────────────────────────────────────────────────────
COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# 병합/스쿼시/기존 메시지 재사용(-c/-C/--amend)엔 중복 방지 위해 스킵
case "$COMMIT_SOURCE" in
  merge|squash|commit) exit 0 ;;
esac

# 이모티콘 목록 (작은따옴표로 감싸 backtick/$ 등 특수문자 안전 처리)
KAOMOJI=(
  '٩(๑❛ᴗ❛๑)۶' '( ˘⌣˘)♡' '(⊙_⊙)' '◉_◉' '(◔_◔)' '(°ロ°)'
  '( ͡° ͜ʖ ͡°)' 'ヽ(>∀<☆)☆' '(ﾉ´ヮ`)ﾉ*:･ﾟ✧' '(｡♥‿♥｡)' '(｡•́︿•̀｡)'
  '(ᵔᴥᵔ)' '(*≧ω≦)' '(｡•̀ᴗ-)✧' 'ヾ(＾-＾)ノ' '(˶˃ ᵕ ˂˶)' '(｡˘ᵕ˘｡)'
  'ʕ•ᴥ•ʔ' '(っ˘ω˘ς)' '(੭ ˘ᵕ˘)੭✿' '(。 >ω<｡)' '(♡ >ω< ♡)' '(ﾉ◕ヮ◕)ﾉ*:･ﾟ✧'
)

PICK="${KAOMOJI[$((RANDOM % ${#KAOMOJI[@]}))]}"

# 첫 번째 비주석·비공백 라인(=제목) 끝에 이모티콘을 붙인다.
TMP="$(mktemp)" || exit 0
awk -v kao="  $PICK" '
  !done && $0 !~ /^#/ && NF > 0 { $0 = $0 kao; done = 1 }
  { print }
' "$COMMIT_MSG_FILE" > "$TMP" && mv "$TMP" "$COMMIT_MSG_FILE"

exit 0
