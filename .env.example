# LLM 자동 파싱 설정 예시.
# 이 파일을 .env 로 복사한 뒤 값을 채우면 됩니다:  cp .env.example .env
# .env 는 git에 올라가지 않습니다.

# ── AWS Bedrock Claude 사용 ──────────────────────────────────
LLM_PROVIDER=bedrock
AWS_REGION=ap-northeast-2

# 서울(ap-northeast-2)에서 확인된 사용 가능 모델(인퍼런스 프로파일):
#   Haiku  (빠르고 저렴, 권장 기본):
BEDROCK_MODEL_ID=apac.anthropic.claude-3-haiku-20240307-v1:0
#   Sonnet 3.5 v2 (더 정확, 조금 느림/비쌈):
# BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
#   Sonnet 4 (최신):
# BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# AWS 자격증명은 표준 체인(~/.aws/credentials, 환경변수, IAM 역할 등)을 사용합니다.

# ── 또는 OpenAI 호환 엔드포인트 사용 시 (위 bedrock 설정을 지우고) ──
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
